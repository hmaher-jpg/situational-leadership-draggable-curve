<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Situational Leadership Interactive Curve</title>
  <style>
    /* SAFE OFFLINE SINGLE-FILE INTERACTIVE DEMO
       No CDN, external JS, analytics, storage, cookies, eval, or permissions.
       Optional local images only: s1.png, s2.png, s3.png, s4.png */
    :root {
      --bg-a:#f8fafc; --bg-b:#eef2f7; --ink:#172033; --muted:#64748b;
      --card:rgba(255,255,255,.88); --line:rgba(15,23,42,.82);
      --shadow:0 24px 70px rgba(15,23,42,.14);
      --s1:#dc2626; --s2:#f97316; --s3:#eab308; --s4:#16a34a;
      --active:var(--s1); --active-soft:rgba(220,38,38,.13); --active-dark:#991b1b;
    }
    *{box-sizing:border-box}
    html,body{margin:0;min-height:100%;font-family:Arial,Helvetica,sans-serif;color:var(--ink);background:radial-gradient(circle at top left,rgba(125,211,252,.20),transparent 34%),radial-gradient(circle at bottom right,rgba(249,115,22,.13),transparent 36%),linear-gradient(135deg,var(--bg-a),var(--bg-b))}
    body{overflow-x:hidden} button{font:inherit}
    .app{min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:24px 16px 34px}
    .topbar{width:min(1180px,100%);display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:18px}
    .brand{display:flex;align-items:center;gap:13px}
    .brand-mark{width:46px;height:46px;border-radius:15px;display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;overflow:hidden;box-shadow:0 14px 34px rgba(15,23,42,.16)}
    .brand-mark span:nth-child(1){background:var(--s3)}.brand-mark span:nth-child(2){background:var(--s2)}.brand-mark span:nth-child(3){background:var(--s4)}.brand-mark span:nth-child(4){background:var(--s1)}
    .brand h1{margin:0;font-size:clamp(24px,3.5vw,42px);letter-spacing:-.04em;line-height:1}
    .brand p{margin:5px 0 0;color:var(--muted);font-size:15px}
    .layout{width:min(1180px,100%);display:grid;grid-template-columns:minmax(360px,1.08fr) minmax(310px,.92fr);gap:24px;align-items:stretch}
    .diagram-card,.info-card{background:var(--card);border:1px solid rgba(148,163,184,.30);border-radius:30px;box-shadow:var(--shadow);backdrop-filter:blur(12px);overflow:hidden}
    .diagram-card{padding:clamp(16px,2.6vw,28px)}
    .hint-row{display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:space-between;margin-bottom:14px}
    .hint{display:inline-flex;align-items:center;gap:8px;padding:8px 11px;border-radius:999px;background:rgba(15,23,42,.06);color:#334155;font-size:13px;font-weight:700}
    .reset-btn{border:0;cursor:pointer;padding:9px 13px;border-radius:999px;background:var(--active-soft);color:var(--active-dark);font-weight:800;transition:transform .16s ease,background .16s ease}
    .reset-btn:hover,.reset-btn:focus-visible{transform:translateY(-2px);outline:none;background:rgba(15,23,42,.09)}
    .diagram-wrap{position:relative;width:100%;border-radius:24px;background:radial-gradient(circle at 50% 48%,rgba(255,255,255,.95),rgba(255,255,255,.70) 58%,rgba(241,245,249,.80)),linear-gradient(135deg,rgba(255,255,255,.94),rgba(248,250,252,.76));border:1px solid rgba(148,163,184,.25);overflow:hidden;touch-action:none;user-select:none}
    svg{display:block;width:100%;height:auto}
    .axis-label{fill:#172033;font-size:16px;font-weight:800}.axis-note{fill:#475569;font-size:12px;font-weight:700}
    .quad-label{fill:#172033;font-size:25px;font-weight:900;paint-order:stroke;stroke:rgba(255,255,255,.9);stroke-width:5;stroke-linejoin:round}
    .style-name{fill:#334155;font-size:14px;font-weight:800;paint-order:stroke;stroke:rgba(255,255,255,.9);stroke-width:4;stroke-linejoin:round}
    .grid-line{stroke:rgba(15,23,42,.62);stroke-width:1.5}.outer-box{fill:rgba(255,255,255,.24);stroke:var(--line);stroke-width:2.2}
    .curve-shadow{fill:none;stroke:rgba(15,23,42,.13);stroke-width:13;stroke-linecap:round;stroke-linejoin:round}
    .curve-path{fill:none;stroke:#111827;stroke-width:5.5;stroke-linecap:round;stroke-linejoin:round}
    .curve-click-zone{fill:none;stroke:transparent;stroke-width:52;stroke-linecap:round;stroke-linejoin:round;cursor:grab}
    .curve-click-zone:active{cursor:grabbing}
    .marker-pulse{fill:var(--active);opacity:.14;transform-box:fill-box;transform-origin:center;animation:pulse 1700ms ease-in-out infinite}
    .marker{fill:var(--active);stroke:white;stroke-width:5;filter:drop-shadow(0 10px 18px rgba(15,23,42,.24));cursor:grab}
    .marker:active{cursor:grabbing}.marker-letter{fill:white;font-size:18px;font-weight:900;pointer-events:none}
    @keyframes pulse{0%,100%{r:23;opacity:.14}50%{r:34;opacity:.24}}
    .info-card{position:relative;display:flex;flex-direction:column;padding:clamp(18px,2.5vw,28px)}
    .info-card::before{content:"";position:absolute;inset:-20% -40% auto auto;width:70%;height:55%;background:radial-gradient(circle,var(--active-soft),transparent 62%);pointer-events:none}
    .style-badge{position:relative;z-index:2;align-self:flex-start;display:inline-flex;align-items:center;gap:9px;padding:9px 12px;border-radius:999px;background:var(--active-soft);color:var(--active-dark);font-weight:900;letter-spacing:.02em}
    .badge-dot{width:13px;height:13px;border-radius:50%;background:var(--active);box-shadow:0 0 0 6px var(--active-soft)}
    .photo-frame{position:relative;z-index:2;margin-top:18px;width:100%;aspect-ratio:16/10;border-radius:24px;overflow:hidden;background:linear-gradient(135deg,rgba(255,255,255,.86),rgba(241,245,249,.70)),repeating-linear-gradient(45deg,rgba(148,163,184,.12) 0 8px,transparent 8px 16px);border:1px solid rgba(148,163,184,.35);display:grid;place-items:center;box-shadow:0 16px 38px rgba(15,23,42,.08)}
    .photo-frame img{width:100%;height:100%;object-fit:cover;display:none}.photo-placeholder{padding:22px;text-align:center;color:#64748b}
    .photo-placeholder strong{display:block;color:#334155;font-size:18px;margin-bottom:7px}.photo-placeholder span{font-size:14px;line-height:1.45}
    .curve-follower-card{margin-top:14px;padding:14px 16px;border-radius:20px;background:var(--active-soft);border:1px solid rgba(148,163,184,.28);color:#334155;box-shadow:0 10px 24px rgba(15,23,42,.05)}
    .curve-follower-card strong{display:block;color:var(--active-dark);font-size:15px;margin-bottom:5px}.curve-follower-card span{font-size:14px;line-height:1.45}
    .info-title{position:relative;z-index:2;margin:22px 0 8px;font-size:clamp(34px,5vw,56px);line-height:.95;letter-spacing:-.06em;color:var(--active-dark)}
    .info-subtitle{position:relative;z-index:2;margin:0 0 16px;color:#475569;font-size:18px;line-height:1.5}
    .info-list{position:relative;z-index:2;display:grid;gap:10px;margin:0;padding:0;list-style:none}
    .info-list li{display:grid;grid-template-columns:30px 1fr;gap:11px;align-items:start;padding:12px 13px;border-radius:16px;background:rgba(255,255,255,.70);border:1px solid rgba(148,163,184,.22);color:#334155;line-height:1.45;box-shadow:0 10px 24px rgba(15,23,42,.05)}
    .info-list b{width:30px;height:30px;border-radius:11px;display:grid;place-items:center;background:var(--active-soft);color:var(--active-dark);font-size:13px}
    .mini-nav{position:relative;z-index:2;display:flex;flex-wrap:wrap;gap:9px;margin-top:18px}
    .mini-nav button{border:0;min-width:52px;cursor:pointer;padding:10px 12px;border-radius:999px;background:rgba(255,255,255,.80);color:#334155;font-weight:900;box-shadow:0 10px 24px rgba(15,23,42,.07);transition:transform .16s ease,background .16s ease,color .16s ease}
    .mini-nav button:hover,.mini-nav button:focus-visible{transform:translateY(-2px);outline:none}.mini-nav button.active{background:var(--active);color:white}
    .instructions{width:min(1180px,100%);margin-top:16px;color:#64748b;font-size:14px;text-align:center;line-height:1.5}
    @media (max-width:920px){.layout{grid-template-columns:1fr}.topbar{align-items:flex-start}.info-card{min-height:auto}}
    @media (max-width:560px){.app{padding:18px 10px 28px}.brand h1{font-size:25px}.diagram-card,.info-card{border-radius:22px}.diagram-card{padding:10px}.hint-row{padding:4px}.hint{font-size:12px}.axis-label{font-size:13px}.axis-note{font-size:10px}.quad-label{font-size:22px}.style-name{font-size:12px}.info-title{font-size:34px}.info-subtitle{font-size:16px}.photo-frame{border-radius:18px}}
  </style>
</head>
<body>
  <main class="app">
    <header class="topbar">
      <div class="brand" aria-label="Situational Leadership interactive demo">
        <div class="brand-mark" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
        <div><h1>Situational Leadership Interactive</h1><p>Move the circle along the curve to explore the four leadership styles.</p></div>
      </div>
    </header>

    <section class="layout" aria-label="Situational Leadership interactive model">
      <article class="diagram-card">
        <div class="hint-row"><span class="hint">● Drag the circle on the curve</span><button id="resetBtn" class="reset-btn" type="button">Reset to S1</button></div>
        <div class="diagram-wrap" id="diagramWrap">
          <svg id="modelSvg" viewBox="0 0 760 620" role="img" aria-label="Situational Leadership model with task behavior and supportive behavior axes">
            <rect x="120" y="58" width="560" height="458" rx="2" class="outer-box" />
            <line x1="400" y1="58" x2="400" y2="516" class="grid-line" />
            <line x1="120" y1="287" x2="680" y2="287" class="grid-line" />
            <rect id="qS3" x="120" y="58" width="280" height="229" fill="#eab308" opacity="0.06" />
            <rect id="qS2" x="400" y="58" width="280" height="229" fill="#f97316" opacity="0.06" />
            <rect id="qS4" x="120" y="287" width="280" height="229" fill="#16a34a" opacity="0.06" />
            <rect id="qS1" x="400" y="287" width="280" height="229" fill="#dc2626" opacity="0.06" />
            <line x1="120" y1="540" x2="680" y2="540" stroke="#172033" stroke-width="2.2" />
            <polygon points="120,540 135,532 135,548" fill="#172033" /><polygon points="680,540 665,532 665,548" fill="#172033" />
            <line x1="94" y1="516" x2="94" y2="58" stroke="#172033" stroke-width="2.2" />
            <polygon points="94,58 86,73 102,73" fill="#172033" /><polygon points="94,516 86,501 102,501" fill="#172033" />
            <text x="400" y="580" text-anchor="middle" class="axis-label">Task Behavior</text>
            <text x="400" y="600" text-anchor="middle" class="axis-note">(Directing Behavior)</text>
            <text x="136" y="563" text-anchor="middle" class="axis-note">Low</text><text x="660" y="563" text-anchor="middle" class="axis-note">High</text>
            <text x="52" y="287" text-anchor="middle" class="axis-label" transform="rotate(-90 52 287)">Supportive Behavior</text>
            <text x="75" y="287" text-anchor="middle" class="axis-note" transform="rotate(-90 75 287)">(Relationship Behavior)</text>
            <text x="94" y="36" text-anchor="middle" class="axis-note">High</text><text x="94" y="548" text-anchor="middle" class="axis-note">Low</text>
            <text x="330" y="278" text-anchor="middle" class="quad-label">S3</text><text x="235" y="132" text-anchor="middle" class="style-name" transform="rotate(-28 235 132)">Supporting</text>
            <text x="470" y="278" text-anchor="middle" class="quad-label">S2</text><text x="565" y="132" text-anchor="middle" class="style-name" transform="rotate(28 565 132)">Coaching</text>
            <text x="165" y="488" text-anchor="middle" class="quad-label">S4</text><text x="205" y="355" text-anchor="middle" class="style-name" transform="rotate(-24 205 355)">Delegating</text>
            <text x="635" y="488" text-anchor="middle" class="quad-label">S1</text><text x="595" y="355" text-anchor="middle" class="style-name" transform="rotate(24 595 355)">Directing</text>
            <path id="stylePathShadow" d="M 120 446 C 198 414, 242 382, 270 315 C 291 250, 285 167, 400 160 C 515 167, 509 250, 530 315 C 558 382, 602 414, 680 446" class="curve-shadow" />
            <path id="stylePath" d="M 120 446 C 198 414, 242 382, 270 315 C 291 250, 285 167, 400 160 C 515 167, 509 250, 530 315 C 558 382, 602 414, 680 446" class="curve-path" />
            <path id="dragPath" d="M 120 446 C 198 414, 242 382, 270 315 C 291 250, 285 167, 400 160 C 515 167, 509 250, 530 315 C 558 382, 602 414, 680 446" class="curve-click-zone" />
            <g id="markerGroup" aria-label="Move along the Situational Leadership curve">
              <circle id="markerPulse" class="marker-pulse" cx="680" cy="446" r="24"></circle><circle id="marker" class="marker" cx="680" cy="446" r="21"></circle><text id="markerText" x="680" y="452" text-anchor="middle" class="marker-letter">S1</text>
            </g>
          </svg>
        </div>
        <div class="curve-follower-card" aria-live="polite">
          <strong id="followerTitle">S1: Telling / Directing</strong>
          <span id="followerText">Follower: D1: Low competence, High commitment / Unable and over-confident</span>
        </div>
      </article>

      <aside class="info-card" id="infoCard" aria-live="polite">
        <div class="style-badge"><span class="badge-dot"></span><span id="badgeText">S1 — Directing</span></div>
        <div class="photo-frame"><img id="stylePhoto" src="s1.png" alt="Local image for S1 Directing style" /><div id="photoPlaceholder" class="photo-placeholder"><strong>Image placeholder</strong><span>Add <b id="fileNameText">s1.png</b> in the same folder as this HTML file. The page still works without it.</span></div></div>
        <h2 class="info-title" id="styleTitle">S1 Directing</h2>
        <p class="info-subtitle" id="styleSubtitle">High direction, low support. Best when the employee needs clear instructions and close supervision.</p>
        <ul class="info-list" id="infoList"></ul>
        <div class="mini-nav" aria-label="Jump to leadership style"><button type="button" data-style="s1" class="active">S1</button><button type="button" data-style="s2">S2</button><button type="button" data-style="s3">S3</button><button type="button" data-style="s4">S4</button></div>
      </aside>
    </section>
    <p class="instructions">Tip: drag the circle, click/tap anywhere on the curve, or use the S1–S4 buttons.</p>
  </main>

  <script>
    const styles={s1:{id:'S1',name:'Directing',color:'#dc2626',dark:'#991b1b',soft:'rgba(220,38,38,.13)',image:'s1.png',followerTitle:'S1: Telling / Directing',follower:'Follower: D1: Low competence, High commitment / Unable and over-confident',subtitle:'High direction, low support. Best when the employee needs clear instructions and close supervision.',bullets:['Use when competence is low but the person still needs structure to start correctly.','Tell clearly what to do, how to do it, when to do it, and what standard is expected.','Avoid using this style too long after the person becomes more competent.'],pathRatio:1},s2:{id:'S2',name:'Coaching',color:'#f97316',dark:'#9a3412',soft:'rgba(249,115,22,.15)',image:'s2.png',followerTitle:'S2: Selling / Coaching',follower:'Follower: D2: Some competence, Low commitment / Unable but unwilling or de-motivated',subtitle:'High direction, high support. Best when the employee still needs guidance but also needs encouragement.',bullets:['Explain decisions, clarify the task, and invite questions.','Keep structure in place while rebuilding confidence and motivation.','Useful when the person has some competence but commitment has dropped.'],pathRatio:.67},s3:{id:'S3',name:'Supporting',color:'#eab308',dark:'#a16207',soft:'rgba(234,179,8,.18)',image:'s3.png',followerTitle:'S3: Participating / Supporting',follower:'Follower: D3: High competence, Variable commitment / Able but unwilling or insecure',subtitle:'Low direction, high support. Best when the employee can do the task but needs confidence or involvement.',bullets:['Listen, encourage, and involve the person in decision-making.','Let the employee lead more of the thinking while you provide support.','Useful when competence is high but commitment is variable.'],pathRatio:.33},s4:{id:'S4',name:'Delegating',color:'#16a34a',dark:'#166534',soft:'rgba(22,163,74,.15)',image:'s4.png',followerTitle:'S4: Delegating / Observing',follower:'Follower: D4: High competence, High commitment / Able and willing or motivated',subtitle:'Low direction, low support. Best when the employee is competent, committed, and ready to own the task.',bullets:['Turn over responsibility for decisions and implementation.','Stay available, but do not over-control the work.','Avoid using this style too early with someone who still lacks competence.'],pathRatio:0}};
    const svg=document.getElementById('modelSvg'),stylePath=document.getElementById('stylePath'),dragPath=document.getElementById('dragPath'),markerGroup=document.getElementById('markerGroup'),marker=document.getElementById('marker'),markerPulse=document.getElementById('markerPulse'),markerText=document.getElementById('markerText'),badgeText=document.getElementById('badgeText'),styleTitle=document.getElementById('styleTitle'),styleSubtitle=document.getElementById('styleSubtitle'),infoList=document.getElementById('infoList'),stylePhoto=document.getElementById('stylePhoto'),photoPlaceholder=document.getElementById('photoPlaceholder'),fileNameText=document.getElementById('fileNameText'),followerTitle=document.getElementById('followerTitle'),followerText=document.getElementById('followerText'),resetBtn=document.getElementById('resetBtn'),navButtons=Array.from(document.querySelectorAll('.mini-nav button'));
    const pathLength=stylePath.getTotalLength();let currentLength=pathLength,currentKey='s1',isDragging=false,rafId=null;

    function getSvgPoint(clientX,clientY){
      const matrix=svg.getScreenCTM();
      if(!matrix)return {x:0,y:0};
      const pt=svg.createSVGPoint();
      pt.x=clientX;pt.y=clientY;
      return pt.matrixTransform(matrix.inverse());
    }

    function getEventPosition(event){
      if(event.touches&&event.touches.length)return {x:event.touches[0].clientX,y:event.touches[0].clientY};
      if(event.changedTouches&&event.changedTouches.length)return {x:event.changedTouches[0].clientX,y:event.changedTouches[0].clientY};
      return {x:event.clientX,y:event.clientY};
    }

    function findClosestLength(point){
      let best=0,dist=Infinity;
      const samples=140;
      for(let i=0;i<=samples;i++){
        const len=i/samples*pathLength,p=stylePath.getPointAtLength(len),d=Math.hypot(point.x-p.x,point.y-p.y);
        if(d<dist){dist=d;best=len;}
      }
      const step=pathLength/samples,start=Math.max(0,best-step),end=Math.min(pathLength,best+step);
      for(let i=0;i<=36;i++){
        const len=start+(end-start)*i/36,p=stylePath.getPointAtLength(len),d=Math.hypot(point.x-p.x,point.y-p.y);
        if(d<dist){dist=d;best=len;}
      }
      return best;
    }

    function getNearestStyleKey(length){
      const ratio=length/pathLength;
      let bestKey='s1',bestDelta=Infinity;
      Object.keys(styles).forEach(key=>{const delta=Math.abs(ratio-styles[key].pathRatio);if(delta<bestDelta){bestDelta=delta;bestKey=key;}});
      return bestKey;
    }

    function setCssColors(data){document.documentElement.style.setProperty('--active',data.color);document.documentElement.style.setProperty('--active-dark',data.dark);document.documentElement.style.setProperty('--active-soft',data.soft);}
    function updateQuadrantOpacity(activeKey){['S1','S2','S3','S4'].forEach(id=>{const rect=document.getElementById('q'+id);if(rect)rect.setAttribute('opacity',activeKey===id.toLowerCase()?'.18':'.06');});}

    function updateInfo(key){
      const data=styles[key];if(!data)return;
      currentKey=key;setCssColors(data);updateQuadrantOpacity(key);
      markerText.textContent=data.id;
      badgeText.textContent=data.id+' — '+data.name;styleTitle.textContent=data.id+' '+data.name;styleSubtitle.textContent=data.subtitle;followerTitle.textContent=data.followerTitle;followerText.textContent=data.follower;
      fileNameText.textContent=data.image;stylePhoto.style.display='none';photoPlaceholder.style.display='block';stylePhoto.alt='Local image for '+data.id+' '+data.name+' style';stylePhoto.src=data.image;
      infoList.innerHTML='';
      data.bullets.forEach((text,index)=>{const li=document.createElement('li'),num=document.createElement('b'),span=document.createElement('span');num.textContent=index+1;span.textContent=text;li.appendChild(num);li.appendChild(span);infoList.appendChild(li);});
      navButtons.forEach(button=>button.classList.toggle('active',button.dataset.style===key));
    }

    function updateMarker(length,snapStyle){
      currentLength=Math.max(0,Math.min(pathLength,length));
      const p=stylePath.getPointAtLength(currentLength);
      marker.setAttribute('cx',p.x);marker.setAttribute('cy',p.y);markerPulse.setAttribute('cx',p.x);markerPulse.setAttribute('cy',p.y);markerText.setAttribute('x',p.x);markerText.setAttribute('y',p.y+6);
      const key=snapStyle||getNearestStyleKey(currentLength);
      if(key!==currentKey)updateInfo(key);
    }

    function moveToStyle(key){const data=styles[key];if(!data)return;updateMarker(data.pathRatio*pathLength,key);updateInfo(key);}

    function moveFromEvent(event){
      const pos=getEventPosition(event);
      if(typeof pos.x!=='number'||typeof pos.y!=='number')return;
      const point=getSvgPoint(pos.x,pos.y);
      const length=findClosestLength(point);
      if(rafId)cancelAnimationFrame(rafId);
      rafId=requestAnimationFrame(()=>updateMarker(length));
    }

    function startDrag(event){
      if(event.type==='mousedown'&&event.button!==0)return;
      isDragging=true;
      event.preventDefault();
      moveFromEvent(event);
      document.addEventListener('mousemove',dragMove);
      document.addEventListener('mouseup',endDrag);
      document.addEventListener('touchmove',dragMove,{passive:false});
      document.addEventListener('touchend',endDrag);
      document.addEventListener('touchcancel',endDrag);
    }

    function dragMove(event){
      if(!isDragging)return;
      event.preventDefault();
      moveFromEvent(event);
    }

    function endDrag(event){
      if(!isDragging)return;
      if(event&&event.cancelable)event.preventDefault();
      isDragging=false;
      if(rafId){cancelAnimationFrame(rafId);rafId=null;}
      moveToStyle(getNearestStyleKey(currentLength));
      document.removeEventListener('mousemove',dragMove);
      document.removeEventListener('mouseup',endDrag);
      document.removeEventListener('touchmove',dragMove);
      document.removeEventListener('touchend',endDrag);
      document.removeEventListener('touchcancel',endDrag);
    }

    markerGroup.addEventListener('mousedown',startDrag);
    dragPath.addEventListener('mousedown',startDrag);
    markerGroup.addEventListener('touchstart',startDrag,{passive:false});
    dragPath.addEventListener('touchstart',startDrag,{passive:false});
    window.addEventListener('blur',endDrag);
    navButtons.forEach(button=>button.addEventListener('click',()=>moveToStyle(button.dataset.style)));
    resetBtn.addEventListener('click',()=>moveToStyle('s1'));
    stylePhoto.addEventListener('load',()=>{stylePhoto.style.display='block';photoPlaceholder.style.display='none'});stylePhoto.addEventListener('error',()=>{stylePhoto.style.display='none';photoPlaceholder.style.display='block'});
    moveToStyle('s1');
  </script>
</body>
</html>
